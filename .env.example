# Frontend (raíz del proyecto)
# Puerto en el que corre la app React (npm start)
PORT=3003

# URL del backend. Para desarrollo local no hace falta (por defecto http://localhost:8010).
# Para despliegue en servidor (ej. Docker en 172.16.222.222), descomentar y usar la URL pública del API:
# REACT_APP_API_URL=http://172.16.222.222:8010
