# Copiar a .env y completar con valores reales (no subir .env a Git)
# Backend FastAPI - bases de datos
#
# Si corrés el backend en Docker y PostgreSQL está en tu PC (no en un contenedor),
# usá host.docker.internal como host para que el contenedor pueda conectar:
#   DB_CID_HOST=host.docker.internal
#   DB_MON_HOST=host.docker.internal
#   DB_BILL_HOST=host.docker.internal

DB_CID_HOST=
DB_CID_USER=
DB_CID_PASSWORD=
DB_CID_NAME=
DB_CID_PORT=2024

DB_MON_HOST=
DB_MON_USER=
DB_MON_PASSWORD=
DB_MON_NAME=
DB_MON_PORT=5432

DB_BILL_HOST=
DB_BILL_USER=
DB_BILL_PASSWORD=
DB_BILL_NAME=
DB_BILL_PORT=5432
